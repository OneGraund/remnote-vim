{
  "private": true,
  "name": "remnote-vim",
  "version": "0.1.0",
  "description": "Modal, vim-style editing for the RemNote desktop app, as a RemNote plugin.",
  "author": "onegraund",
  "license": "MIT",
  "homepage": "https://github.com/onegraund/remnote-vim#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/onegraund/remnote-vim.git"
  },
  "bugs": {
    "url": "https://github.com/onegraund/remnote-vim/issues"
  },
  "keywords": [
    "remnote",
    "remnote-plugin",
    "vim",
    "modal-editing",
    "keyboard"
  ],
  "scripts": {
    "check-types": "tsc",
    "dev": "NODE_ENV=development webpack-dev-server --color --no-open",
    "build": "rm -rf dist PluginZip.zip && NODE_ENV=production webpack --color && cd dist && zip -r ../PluginZip.zip .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node e2e/run.mjs",
    "e2e:reallife": "node e2e/reallife.mjs"
  },
  "dependencies": {
    "@remnote/plugin-sdk": "^0.0.46",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@types/node": "^18.0.3",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "copy-webpack-plugin": "^11.0.0",
    "esbuild-loader": "^2.19.0",
    "glob": "^8.0.3",
    "html-webpack-plugin": "^5.5.0",
    "playwright-core": "^1.45.0",
    "typescript": "^4.7.4",
    "vitest": "^1.6.0",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.9.3"
  }
}
