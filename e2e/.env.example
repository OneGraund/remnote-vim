# Credentials for the live end-to-end harness (e2e/).
# Copy to e2e/.env and fill in a RemNote account used ONLY for testing.
# e2e/.env is gitignored — never commit real credentials.
#
# The harness logs this account into a throwaway RemNote instance and types
# real keystrokes into a scratch bullet in today's Daily Document, then cleans
# up after itself. Use a disposable/test account, not your primary one.
REMNOTE_E2E_EMAIL=you@example.com
REMNOTE_E2E_PASSWORD=your-test-account-password
